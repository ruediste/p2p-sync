{
  "name": "tsdown-starter",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "build": "esbuild src/index.ts --bundle --platform=node --packages=external --outfile=dist/index.mjs --sourcemap --format=esm",
    "gen": "buf generate",
    "node1": "mkdir -p data/node1 && cd data/node1 && node ../../dist/index.mjs 7743",
    "node2": "mkdir -p data/node2 && cd data/node2 && node ../../dist/index.mjs 7744",
    "dev:build": "esbuild src/index.ts --bundle --platform=node --packages=external --outfile=dist/index.mjs --format=esm --sourcemap --watch"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.1",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/reload": "^3.2.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "express": "^5.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.4.9",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@helia/dag-json": "^5.0.7",
    "@helia/http": "^3.0.20",
    "@helia/ipns": "^9.1.9",
    "@helia/unixfs": "^7.0.4",
    "@libp2p/autonat": "^3.0.10",
    "@libp2p/autonat-v2": "^2.0.12",
    "@libp2p/circuit-relay-v2": "^4.1.3",
    "@libp2p/kad-dht": "^16.1.3",
    "@libp2p/mdns": "^12.0.11",
    "@libp2p/ping": "^3.0.10",
    "@libp2p/upnp-nat": "^4.0.10",
    "blockstore-fs": "^3.0.2",
    "datastore-fs": "^11.0.2",
    "dns-packet": "^5.6.1",
    "helia": "^6.0.20",
    "multicast-dns": "^7.2.5",
    "reload": "^3.4.2"
  }
}
